---
export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/images/logo_dr.png',
  noindex = false,
} = Astro.props;

const siteName = 'DDr. Anastasiya Krusche — Gynäkologin';
const siteUrl = 'https://www.dr-krusche.at';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  '@id': siteUrl,
  name: 'DDr. Anastasiya Krusche',
  description: 'Fachärztin für Gynäkologie und Geburtshilfe, Ärztin für Allgemeinmedizin.',
  url: siteUrl,
  telephone: ['+43 2236 392137', '+43 2773 43603'],
  email: 'office@dr-krusche.at',
  image: `${siteUrl}/images/logo_dr.png`,
  priceRange: '$$',
  medicalSpecialty: 'Gynecology',
  availableLanguage: ['German', 'Russian', 'English'],
  address: [
    {
      '@type': 'PostalAddress',
      streetAddress: 'Enzersdorfer Straße 70/1',
      addressLocality: 'Mödling',
      postalCode: '2340',
      addressCountry: 'AT',
    },
    {
      '@type': 'PostalAddress',
      streetAddress: 'Hochstraß 593',
      addressLocality: 'Hochstraß',
      postalCode: '3033',
      addressCountry: 'AT',
    },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Thursday'],
      opens: '08:00',
      closes: '13:00',
      description: 'Ordination Mödling',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Wednesday',
      opens: '13:00',
      closes: '18:00',
      description: 'Ordination Mödling',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Monday',
      opens: '15:00',
      closes: '19:00',
      description: 'Ordination Hochstraß',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Wednesday',
      opens: '08:00',
      closes: '12:00',
      description: 'Ordination Hochstraß',
    },
  ],
};
import LanguageToggle from '../components/LanguageToggle.astro';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="de_AT" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/logo_dr.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Global Styles -->
    <style is:global>
      /* Reset & Base */
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; -webkit-text-size-adjust: 100%; overflow-x: hidden; }
      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        font-size: 17px; line-height: 1.75; color: #1A1A2E; background-color: #FAFAF8;
        overflow-x: hidden; -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale;
      }
      h1, h2, h3 { font-family: 'Playfair Display', Georgia, 'Times New Roman', serif; font-weight: 700; line-height: 1.2; color: #1A1A2E; }
      h1 { font-size: 52px; letter-spacing: -0.5px; }
      h2 { font-size: 38px; letter-spacing: -0.3px; }
      h3 { font-size: 26px; }
      a { color: #2C3E6B; text-decoration: none; transition: color 0.2s ease; }
      a:hover { color: #1E2D52; }
      img { max-width: 100%; height: auto; display: block; }
      ul, ol { list-style: none; }

      /* Container */
      .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

      /* Buttons */
      .btn {
        display: inline-flex; align-items: center; justify-content: center; gap: 8px;
        padding: 14px 32px; font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600;
        line-height: 1; border: 2px solid transparent; border-radius: 8px; cursor: pointer;
        transition: all 0.25s ease; text-decoration: none; white-space: nowrap;
      }
      .btn:focus-visible { outline: 3px solid #2C3E6B; outline-offset: 2px; }
      .btn-primary { background-color: #2C3E6B; color: #FFFFFF; border-color: #2C3E6B; }
      .btn-primary:hover { background-color: #1E2D52; border-color: #1E2D52; color: #FFFFFF; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(44,62,107,0.3); }
      .btn-outline { background-color: transparent; color: #2C3E6B; border-color: #2C3E6B; }
      .btn-outline:hover { background-color: #2C3E6B; color: #FFFFFF; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(44,62,107,0.2); }
      .btn-white { background-color: #FFFFFF; color: #2C3E6B; border-color: #FFFFFF; }
      .btn-white:hover { background-color: #F2F2F0; border-color: #F2F2F0; color: #1E2D52; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.15); }
      .btn-call { background-color: #2C3E6B; color: #FFFFFF; border-color: #2C3E6B; padding: 12px 24px; font-size: 15px; border-radius: 50px; }
      .btn-call:hover { background-color: #1E2D52; border-color: #1E2D52; color: #FFFFFF; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(44,62,107,0.35); }
      .btn-call svg, .btn-call .icon { width: 18px; height: 18px; }

      /* Navigation */
      .nav { position: sticky; top: 0; z-index: 1000; background-color: #FFFFFF; border-bottom: 1px solid #E8E4E0; transition: box-shadow 0.3s ease, background-color 0.3s ease; }
      .nav.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.08); border-bottom-color: transparent; }
      .nav-inner { display: flex; align-items: center; justify-content: space-between; height: 80px; max-width: 1200px; margin: 0 auto; padding: 0 24px; }
      .nav-logo { font-family: 'Playfair Display', Georgia, serif; font-size: 24px; font-weight: 700; color: #2C3E6B; text-decoration: none; letter-spacing: -0.3px; display: flex; align-items: center; gap: 10px; min-width: 0; }
      .nav-logo:hover { color: #1E2D52; }
      .nav-logo span { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
      .nav-logo-img { height: 63px; width: auto; display: block; }
      .nav-links { display: flex; align-items: center; gap: 8px; list-style: none; }
      .nav-links a { display: block; padding: 8px 16px; font-size: 15px; font-weight: 500; color: #4A4A6A; text-decoration: none; border-radius: 6px; white-space: nowrap; transition: color 0.2s ease, background-color 0.2s ease; }
      .nav-links a.btn { color: #FFFFFF; }
      .nav-links a:hover, .nav-links a.active { color: #2C3E6B; background-color: #F2F2F0; }
      .nav-links a.btn:hover, .nav-links a.btn.active { color: #FFFFFF; background-color: #1E2D52; border-color: #1E2D52; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(44,62,107,0.3); }

      /* Navigation Dropdown */
      .nav-dropdown { position: relative; }
      .nav-dropdown-toggle { display: flex; align-items: center; gap: 4px; padding: 8px 16px; font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 500; color: #4A4A6A; background: none; border: none; border-radius: 6px; white-space: nowrap; cursor: pointer; transition: color 0.2s ease, background-color 0.2s ease; }
      .nav-dropdown-toggle:hover, .nav-dropdown-toggle.active { color: #2C3E6B; background-color: #F2F2F0; }
      .nav-dropdown-toggle::after { content: ''; display: inline-block; width: 6px; height: 6px; border-right: 2px solid currentColor; border-bottom: 2px solid currentColor; transform: rotate(45deg); margin-top: -3px; transition: transform 0.2s ease; }
      .nav-dropdown:hover .nav-dropdown-toggle::after { transform: rotate(-135deg); }
      .nav-dropdown-menu { position: absolute; top: 100%; left: 0; min-width: 220px; background-color: #FFFFFF; border: 1px solid #E8E4E0; border-radius: 10px; box-shadow: 0 8px 30px rgba(0,0,0,0.1); padding: 8px; opacity: 0; visibility: hidden; transform: translateY(8px); transition: all 0.25s ease; list-style: none; }
      .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
      .nav-dropdown-menu a { display: block; padding: 10px 16px; font-size: 14px; font-weight: 500; color: #4A4A6A; border-radius: 6px; transition: background-color 0.15s ease, color 0.15s ease; }
      .nav-dropdown-menu a:hover { background-color: #F2F2F0; color: #2C3E6B; }

      /* Hamburger */
      .nav-hamburger { display: none; flex-direction: column; justify-content: center; gap: 5px; width: 40px; height: 40px; padding: 8px; background: none; border: none; cursor: pointer; }
      .nav-hamburger span { display: block; width: 24px; height: 2px; background-color: #1A1A2E; border-radius: 2px; transition: all 0.3s ease; }
      .nav-hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
      .nav-hamburger.active span:nth-child(2) { opacity: 0; }
      .nav-hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

      /* Mobile Menu */
      .mobile-menu { display: none; position: fixed; top: 80px; left: 0; right: 0; bottom: 0; background-color: #FFFFFF; padding: 24px; overflow-y: auto; z-index: 999; }
      .mobile-menu.active { display: block; }
      .mobile-menu a { display: block; padding: 14px 16px; font-size: 17px; font-weight: 500; color: #1A1A2E; border-bottom: 1px solid #E8E4E0; text-decoration: none; }
      .mobile-menu a:hover, .mobile-menu a.active { color: #2C3E6B; background-color: #F2F2F0; }
      .mobile-menu a.btn-primary, .mobile-menu a.btn-primary:hover { color: #FFFFFF; background-color: #2C3E6B; border: 2px solid #2C3E6B; border-radius: 8px; margin-top: 16px; }
      .mobile-menu .nav-dropdown-menu { position: static; opacity: 1; visibility: visible; transform: none; box-shadow: none; border: none; padding: 0 0 0 16px; min-width: unset; }

      /* Language Switcher */
      .lang-btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 500; color: #4A4A6A; background: transparent; border: 1.5px solid #E8E4E0; border-radius: 6px; cursor: pointer; transition: all 0.2s ease; line-height: 1; }
      .lang-btn:hover { border-color: #2C3E6B; color: #2C3E6B; background-color: #F2F2F0; }
      .lang-btn-mobile { display: none; }

      /* Page Hero */
      .page-hero { position: relative; height: 400px; display: flex; align-items: center; justify-content: center; text-align: center; overflow: hidden; }
      .page-hero-image { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; object-position: center top; }
      .page-hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(30,45,82,0.65) 0%, rgba(30,45,82,0.75) 100%); }
      .page-hero-content { position: relative; z-index: 2; color: #FFFFFF; padding: 0 24px; }
      .page-hero-content h1 { color: #FFFFFF; font-size: 48px; margin-bottom: 12px; }
      .page-hero-content p { color: #E0E0EC; font-size: 19px; max-width: 600px; margin: 0 auto; }

      /* Hero Section (Split Layout) */
      .hero { display: flex; align-items: stretch; min-height: 600px; overflow: hidden; }
      .hero-image { flex: 0 0 21%; position: relative; overflow: hidden; }
      .hero-image img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
      .hero-content { flex: 0 0 72%; display: flex; flex-direction: column; justify-content: center; padding: 80px 64px; background-color: #FAFAF8; }
      .hero-overline { display: inline-block; font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #8B6070; margin-bottom: 16px; }
      .hero-content h1 { margin-bottom: 20px; }
      .hero-content p { font-size: 18px; color: #4A4A6A; margin-bottom: 32px; max-width: 500px; }
      .hero-actions { display: flex; flex-wrap: wrap; gap: 16px; }

      /* Vacation Banner */
      .vacation-banner { background-color: #FFF0F0; border: 1px solid #D32F2F; border-left: 5px solid #D32F2F; border-radius: 10px; padding: 20px 28px; margin: 24px 0; display: flex; align-items: flex-start; gap: 16px; }
      .vacation-banner .icon { flex-shrink: 0; width: 24px; height: 24px; color: #D32F2F; margin-top: 2px; }
      .vacation-banner-content h4 { font-family: 'Inter', sans-serif; font-size: 16px; font-weight: 600; color: #B71C1C; margin-bottom: 4px; }
      .vacation-banner-content p { font-size: 15px; color: #B71C1C; line-height: 1.6; }

      /* Info Section */
      .info-section { padding: 48px 0; }
      .info-section .container { max-width: 1440px; }
      .info-section .section-label { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #8B6070; margin-bottom: 12px; }
      .info-section h2 { margin-bottom: 20px; }
      .info-section p { color: #4A4A6A; }
      .info-box { background-color: #FFFFFF; border: 1px solid #E8E4E0; border-left: 4px solid #C9A8B2; border-radius: 10px; padding: 20px 32px; margin-top: 20px; }
      .info-box h3, .info-box h4 { font-family: 'Inter', sans-serif; font-size: 18px; font-weight: 600; color: #1A1A2E; margin-bottom: 8px; }
      .info-box p { color: #4A4A6A; font-size: 16px; }

      /* Leistungen Cards */
      .leistungen-section { padding: 80px 0; background-color: #F2F2F0; }
      .leistungen-section .section-label { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #8B6070; margin-bottom: 12px; text-align: center; }
      .leistungen-header { text-align: center; margin-bottom: 40px; }
      .leistungen-header p { color: #4A4A6A; font-size: 17px; margin-top: 8px; }
      .leistungen-section h2 { text-align: center; margin-bottom: 0; }
      .leistungen-more { text-align: center; margin-top: 40px; }
      .leistungen-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
      .leistung-card { background-color: #FFFFFF; border: 1px solid #E8E4E0; border-radius: 12px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease; cursor: pointer; text-decoration: none; display: block; padding: 0; }
      .leistung-card-img { width: 100%; height: 180px; object-fit: cover; display: block; }
      .leistung-card-body { padding: 20px 24px; text-align: center; }
      .leistung-card-body h3 { font-size: 18px; margin-bottom: 8px; color: #1A1A2E; }
      .leistung-card-body span { display: inline-block; font-size: 14px; font-weight: 600; color: #8B6070; text-decoration: none; transition: color 0.2s ease; }
      .leistung-card:hover .leistung-card-body span { color: #2C3E6B; }
      .leistung-card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,0.08); border-color: #C9A8B2; }

      /* Ordination Sections */
      .ord-section { padding: 80px 0; }
      .ord-section .section-label { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #8B6070; margin-bottom: 12px; }
      .ord-section h2 { margin-bottom: 40px; }
      .ord-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
      .ord-image { border-radius: 16px; overflow: hidden; }
      .ord-image img { width: 100%; height: 100%; min-height: 380px; object-fit: cover; display: block; }
      .ord-text { display: flex; flex-direction: column; gap: 16px; justify-content: center; }
      .ord-text h2 { margin-bottom: 0; }
      .ord-text > p { color: #4A4A6A; margin: 0; }
      .ord-text .btn { align-self: flex-start; margin-top: 4px; }
      .ord-grid.reversed .ord-image { order: 2; }
      .ord-hours-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; font-size: 15px; color: #4A4A6A; border-bottom: 1px solid #E8E4E0; }
      .ord-hours-row:last-child { border-bottom: none; padding-bottom: 0; }
      .ord-hours-row span:last-child { font-weight: 500; }
      .ord-badge { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; background-color: #E8D5DC; color: #8B6070; font-size: 13px; font-weight: 600; border-radius: 50px; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 16px; }
      .ord-hours { background-color: #FFFFFF; border: 1px solid #E8E4E0; border-radius: 12px; padding: 28px 32px; }
      .ord-info-box { background-color: #F2F2F0; border-radius: 12px; padding: 28px 32px; }
      .ord-info-box p { color: #4A4A6A; font-size: 15px; line-height: 1.7; }

      /* CTA Section */
      .cta-section { background-color: #2C3E6B; padding: 80px 0; text-align: center; }
      .cta-section h2 { color: #FFFFFF; margin-bottom: 16px; }
      .cta-section p { color: #E0E0EC; font-size: 18px; max-width: 560px; margin: 0 auto 32px; }
      .cta-section .cta-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: 16px; }
      .cta-section .cta-hint { font-size: 14px; color: rgba(255,255,255,0.8); max-width: 540px; margin: 0 auto 28px; }

      /* Termin Page */
      .termin-section { padding: 80px 0; }
      .termin-block { max-width: 800px; margin: 0 auto 64px; }
      .termin-block:last-child { margin-bottom: 0; }
      .termin-block h2 { margin-bottom: 8px; }
      .termin-badge { display: inline-block; font-size: 14px; font-weight: 600; padding: 6px 16px; border-radius: 20px; background-color: #E8D5DC; color: #8B6070; margin-bottom: 24px; }
      .termin-info { border-left: 4px solid #2C3E6B; padding: 16px 24px; background: #EEF2FA; border-radius: 0 6px 6px 0; margin-bottom: 20px; font-size: 15px; color: #4A4A6A; line-height: 1.65; }
      .termin-warning { border-left: 4px solid #C9A8B2; padding: 16px 24px; background: #FDF6F0; border-radius: 0 6px 6px 0; margin-bottom: 20px; font-size: 15px; font-weight: 500; color: #4A4A6A; line-height: 1.65; }
      .termin-warning-red { border-left: 4px solid #C0392B; padding: 16px 24px; background: #FDECEA; border-radius: 0 6px 6px 0; margin-bottom: 20px; font-size: 15px; font-weight: 600; color: #C0392B; line-height: 1.65; }
      .termin-block .btn { margin-top: 12px; }
      .termin-divider { border: none; border-top: 1px solid #E8E4E0; margin: 0 auto 64px; max-width: 800px; }

      /* Content Pages */
      .content-section { padding: 80px 0; }
      .content-narrow { max-width: 800px; margin: 0 auto; }
      .content-section .section-label { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #8B6070; margin-bottom: 12px; }
      .content-section h2 { margin-bottom: 24px; }
      .content-section p { color: #4A4A6A; margin-bottom: 16px; }
      .content-section p:last-child { margin-bottom: 0; }
      .content-section ul, .content-section ol { margin: 16px 0 24px; padding-left: 0; }
      .content-section ul li, .content-section ol li { position: relative; padding-left: 28px; margin-bottom: 10px; color: #4A4A6A; font-size: 16px; }
      .content-section ul li::before { content: ''; position: absolute; left: 0; top: 10px; width: 8px; height: 8px; background-color: #C9A8B2; border-radius: 50%; }
      .content-section ol { counter-reset: item; }
      .content-section ol li { counter-increment: item; }
      .content-section ol li::before { content: counter(item) '.'; position: absolute; left: 0; font-weight: 600; color: #2C3E6B; }
      .content-info-box { background-color: #F2F2F0; border: 1px solid #E8E4E0; border-radius: 12px; padding: 28px 32px; margin: 32px 0; }
      .content-info-box p { color: #4A4A6A; font-size: 15px; }
      .content-cta { background-color: #2C3E6B; border-radius: 16px; padding: 48px; text-align: center; margin-top: 48px; }
      .content-cta h3 { color: #FFFFFF; margin-bottom: 12px; }
      .content-cta p { color: #E0E0EC; font-size: 17px; margin-bottom: 24px; max-width: 480px; margin-left: auto; margin-right: auto; }

      /* Bio Section */
      .bio-section { padding: 80px 0; }
      .bio-section .section-label { font-family: 'Inter', sans-serif; font-size: 14px; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: #8B6070; margin-bottom: 12px; }
      .bio-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; align-items: start; }
      .bio-image { position: relative; border-radius: 16px; overflow: hidden; }
      .bio-image img { width: 100%; height: auto; display: block; }
      .bio-image::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 4px; background-color: #C9A8B2; }
      .bio-content h2 { margin-bottom: 8px; }
      .bio-content p { color: #4A4A6A; margin-bottom: 16px; }
      .bio-badges { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
      .bio-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 18px; background-color: #F2F2F0; border: 1px solid #E8E4E0; border-radius: 50px; font-size: 14px; font-weight: 500; color: #4A4A6A; margin-right: 8px; margin-bottom: 8px; }
      .bio-diplomas { margin-top: 28px; }
      .bio-diplomas-title { font-size: 14px; font-weight: 600; color: #1A1A2E; margin-bottom: 10px; letter-spacing: 0.3px; }
      .bio-languages { margin-top: 28px; }
      .bio-langs-text { color: #4A4A6A; font-size: 16px; }
      .bio-cta { margin-top: 36px; padding-top: 32px; border-top: 1px solid #E8E4E0; }
      .bio-cta p { font-size: 18px; font-weight: 500; color: #1A1A2E; margin-bottom: 16px; }

      /* Contact Page */
      .kontakt-section { padding: 80px 0; }
      .kontakt-section h2 { margin-bottom: 40px; }
      .kontakt-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; margin-bottom: 48px; }
      .kontakt-card { background-color: #FFFFFF; border: 1px solid #E8E4E0; border-radius: 12px; padding: 32px; transition: box-shadow 0.3s ease; }
      .kontakt-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
      .kontakt-card h3 { font-size: 22px; margin-bottom: 8px; }
      .kontakt-badge { font-size: 13px; font-weight: 600; color: #8B6070; margin-bottom: 20px; display: block; }
      .kontakt-detail { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 12px; font-size: 15px; color: #4A4A6A; }
      .kontakt-detail svg { flex-shrink: 0; margin-top: 3px; color: #8B6070; }
      .kontakt-detail a { color: #2C3E6B; font-weight: 500; }
      .kontakt-detail a:hover { color: #1E2D52; }
      .kontakt-maps-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; margin-top: 48px; }
      .kontakt-map { border-radius: 16px; overflow: hidden; border: 1px solid #E8E4E0; box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
      .kontakt-map iframe { display: block; width: 100%; height: 400px; border: none; }

      /* Footer */
      .footer { background-color: #1E2D52; color: #E0E0EC; padding: 64px 0 0; }
      .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 48px; padding-bottom: 48px; }
      .footer-brand p { font-size: 15px; color: #E0E0EC; line-height: 1.7; max-width: 320px; }
      .footer-logo-img { height: 150px; width: auto; display: block; margin-bottom: 16px; filter: brightness(0) invert(1); }
      .footer h4 { font-family: 'Inter', sans-serif; font-size: 15px; font-weight: 600; color: #FFFFFF; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; }
      .footer-links { list-style: none; }
      .footer-links li { margin-bottom: 10px; }
      .footer-links a { color: #E0E0EC; font-size: 15px; text-decoration: none; transition: color 0.2s ease; }
      .footer-links a:hover { color: #FFFFFF; }
      .footer-contact p { color: #E0E0EC; font-size: 15px; line-height: 1.7; }
      .footer-contact strong { color: #FFFFFF; display: block; margin-top: 16px; margin-bottom: 4px; }
      .footer-contact strong:first-of-type { margin-top: 0; }
      .footer-contact a { color: #FFFFFF; text-decoration: none; transition: color 0.2s ease; }
      .footer-contact a:hover { text-decoration: underline; }
      .footer-bottom { border-top: 1px solid rgba(255,255,255,0.12); padding: 24px 0; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
      .footer-bottom a { color: #FFFFFF; text-decoration: none; transition: color 0.2s ease; }
      .footer-bottom a:hover { text-decoration: underline; }

      /* Impressum & Datenschutz */
      .impressum-section, .datenschutz-section { padding: 80px 0; background-color: #FAFAF8; }
      .impressum-content, .datenschutz-content { max-width: 800px; margin: 0 auto; padding: 0 24px; }
      .impressum-content h1, .datenschutz-content h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 52px; font-weight: 700; color: #1A1A2E; margin-bottom: 32px; line-height: 1.2; }
      .impressum-content h2, .datenschutz-content h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 28px; font-weight: 700; color: #1A1A2E; margin-top: 40px; margin-bottom: 16px; line-height: 1.3; }
      .impressum-content p, .datenschutz-content p { font-size: 17px; line-height: 1.75; color: #1A1A2E; margin-bottom: 16px; }
      .impressum-content a, .datenschutz-content a { color: #2C3E6B; text-decoration: underline; transition: color 0.2s ease; }
      .impressum-content a:hover, .datenschutz-content a:hover { color: #1E2D52; }
      .impressum-content ul, .datenschutz-content ul { list-style: disc; padding-left: 24px; margin: 16px 0 24px; }
      .impressum-content ul li, .datenschutz-content ul li { font-size: 17px; line-height: 1.75; color: #1A1A2E; margin-bottom: 6px; }

      /* Forms */
      .form-group { margin-bottom: 20px; }
      .form-group label { display: block; font-size: 15px; font-weight: 600; color: #1A1A2E; margin-bottom: 6px; }
      .form-group input, .form-group textarea, .form-group select {
        width: 100%; padding: 12px 16px; font-family: 'Inter', sans-serif; font-size: 16px;
        border: 1.5px solid #E8E4E0; border-radius: 8px; background: #FFFFFF; color: #1A1A2E;
        transition: border-color 0.2s ease;
      }
      .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
        outline: none; border-color: #2C3E6B; box-shadow: 0 0 0 3px rgba(44,62,107,0.1);
      }
      .form-group textarea { resize: vertical; min-height: 120px; }
      .form-error { color: #D32F2F; font-size: 14px; margin-top: 4px; }
      .form-success { background: #E8F5E9; border: 1px solid #4CAF50; border-radius: 10px; padding: 20px 28px; margin-bottom: 24px; color: #2E7D32; }
      .form-server-error { background: #FFF0F0; border: 1px solid #D32F2F; border-radius: 10px; padding: 20px 28px; margin-bottom: 24px; color: #B71C1C; }

      /* Screen reader only */
      .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

      /* Responsive: Tablet */
      @media (max-width: 1024px) {
        h1 { font-size: 42px; }
        h2 { font-size: 32px; }
        h3 { font-size: 23px; }
        .nav-links { display: none; }
        .nav-hamburger { display: flex; }
        .lang-btn-mobile { display: inline-flex; }
        .hero { flex-direction: column; min-height: auto; }
        .hero-image { flex: none; width: 100%; height: 400px; order: -1; }
        .hero-image img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
        .hero-content { flex: none; padding: 48px 32px; }
        .leistungen-grid { grid-template-columns: repeat(2, 1fr); }
        .ord-grid { grid-template-columns: 1fr; }
        .bio-grid { grid-template-columns: 1fr; gap: 32px; }
        .bio-image { max-width: 400px; }
        .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
        .footer-brand { grid-column: 1 / -1; }
      }

      /* Responsive: Mobile */
      @media (max-width: 768px) {
        body { font-size: 16px; }
        h1 { font-size: 30px; }
        h2 { font-size: 26px; }
        h3 { font-size: 21px; }
        .container { padding: 0 16px; max-width: 100%; overflow: hidden; }
        .btn { padding: 12px 24px; font-size: 15px; width: 100%; justify-content: center; }
        .hero-actions .btn { width: 100%; }
        .nav-inner { height: 64px; padding: 0 16px; }
        .nav-logo { font-size: 18px; }
        .nav-logo-img { height: 45px; }
        .mobile-menu { top: 64px; }
        .page-hero { height: 260px; }
        .page-hero-content h1 { font-size: 28px; }
        .page-hero-content p { font-size: 16px; }
        .hero { flex-direction: column-reverse; min-height: auto; }
        .hero-image { flex: none; width: 100%; height: auto; max-height: 400px; }
        .hero-image img { width: 100%; height: auto; max-height: 400px; object-fit: cover; }
        .hero-content { flex: none; width: 100%; padding: 40px 16px; }
        .hero-content h1 { font-size: 28px; }
        .hero-content p { font-size: 16px; }
        .hero-actions { flex-direction: column; }
        .hero-actions .btn { width: 100%; }
        .vacation-banner { flex-direction: column; padding: 16px 20px; }
        .info-section { padding: 48px 0; }
        .info-box { padding: 20px 24px; }
        .leistungen-section { padding: 48px 0; }
        .leistungen-grid { grid-template-columns: 1fr; gap: 16px; }
        .ord-section { padding: 48px 0; }
        .ord-grid { grid-template-columns: 1fr; gap: 24px; }
        .ord-grid.reversed .ord-image { order: -1; }
        .ord-hours { padding: 20px 24px; }
        .ord-info-box { padding: 20px 24px; }
        .cta-section { padding: 48px 0; }
        .cta-section h2 { font-size: 26px; }
        .cta-section .cta-actions { flex-direction: column; align-items: center; }
        .cta-section .btn { width: 100%; max-width: 320px; }
        .content-section { padding: 48px 0; }
        .content-cta { padding: 32px 24px; }
        .bio-section { padding: 48px 0; }
        .bio-image { max-width: 100%; }
        .bio-grid { grid-template-columns: 1fr; gap: 24px; }
        .kontakt-section { padding: 48px 0; }
        .kontakt-grid { grid-template-columns: 1fr; gap: 16px; }
        .kontakt-card { padding: 24px; }
        .kontakt-maps-grid { grid-template-columns: 1fr; gap: 24px; }
        .kontakt-map iframe { height: 300px; }
        .footer { padding: 40px 0 0; }
        .footer-grid { grid-template-columns: 1fr; gap: 32px; }
        .footer-brand { grid-column: auto; }
        .footer-logo-img { height: 126px; }
        .footer-bottom { flex-direction: column; text-align: center; }
        .impressum-section, .datenschutz-section { padding: 48px 0; }
        .impressum-content, .datenschutz-content { padding: 0 16px; }
        .impressum-content h1, .datenschutz-content h1 { font-size: 30px; margin-bottom: 24px; }
        .impressum-content h2, .datenschutz-content h2 { font-size: 22px; margin-top: 32px; }
      }
    </style>
  </head>
  <body>
    <slot name="navbar" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
    <LanguageToggle />
  </body>
</html>
