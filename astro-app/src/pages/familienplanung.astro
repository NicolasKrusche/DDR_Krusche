---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Familienplanung & Schwangerschaftsbegleitung — DDr. Anastasiya Krusche"
  description="Familienplanung bei DDr. Krusche: Kinderwunsch, Schwangerschaftsbegleitung, Mutter-Kind-Pass, Pränataldiagnostik, Ultraschall und Blutdruckkontrolle."
>
  <Navbar slot="navbar" />

  <PageHero image="/images/unsplash-NIZeg731LxM.jpg" alt="Familienplanung" title="Familienplanung" />

  <section class="content-section" aria-labelledby="familien-heading">
    <div class="container">
      <div class="content-narrow">
        <h1 class="sr-only" id="familien-heading">Familienplanung</h1>

        <h2 data-lang-de="Kinderwunsch" data-lang-ru="Желание иметь детей">Kinderwunsch</h2>
        <p data-lang-de="Wenn bei Kinderwunsch ein regelmäßiges Sexualleben ein Jahr lang keine Ergebnisse bringt, sollten Sie eine Sterilitätsabklärung in Erwägung ziehen. Dabei kann z.B. festgestellt werden, ob es überhaupt zum Eisprung kommt; ob eine Infektion vorliegt." data-lang-ru="Если Вы хотите иметь детей, а регулярная половая жизнь в течение года не приносит результата, Вам следует пройти обследование на бесплодие. Это позволяет определить, например, происходит ли овуляция вообще; есть ли инфекция.">Wenn bei Kinderwunsch ein regelmäßiges Sexualleben ein Jahr lang keine Ergebnisse bringt, sollten Sie eine Sterilitätsabklärung in Erwägung ziehen. Dabei kann z.B. festgestellt werden, ob es überhaupt zum Eisprung kommt; ob eine Infektion vorliegt.</p>

        <h2 style="margin-top: 40px;" data-lang-de="Untersuchungen" data-lang-ru="Обследования">Untersuchungen</h2>
        <p data-lang-de="Ebenso wie bei der Vorsorge gilt während einer Schwangerschaft: Es ist besser, oft zu untersuchen und nichts finden, als selten zu untersuchen. Viele Risiken können viel leichter entschärft werden, wenn sie früh erkannt werden." data-lang-ru="Как и при скрининге, то же самое касается и беременности: Лучше проверять чаще и ничего не находить, чем проверять редко. Многие риски можно обезвредить гораздо легче, если заметить их на ранней стадии.">Ebenso wie bei der Vorsorge gilt während einer Schwangerschaft: Es ist besser, oft zu untersuchen und nichts finden, als selten zu untersuchen. Viele Risiken können viel leichter entschärft werden, wenn sie früh erkannt werden.</p>

        <h3 style="margin-top: 28px; margin-bottom: 12px;" data-lang-de="Mutter-Kind-Pass" data-lang-ru="Паспорт матери и ребенка">Mutter-Kind-Pass</h3>
        <p data-lang-de="Für den Mutter-Kind-Pass sind 5 Untersuchungen, im Abstand von jeweils ca. einem Monat, vorgesehen. Dabei werden z.B. Hämoglobin/Hämatokritwerte festgestellt, Risikofaktoren für Kind und Mutter etabliert, und ausführliche Anamnese (=Gesundheitliche Vorgeschichte) durchgeführt." data-lang-ru="Для паспорта матери и ребенка запланировано 5 осмотров, каждый с интервалом примерно в один месяц. Например, определяются показатели гемоглобина/гематокрита, устанавливаются факторы риска для ребенка и матери, собирается подробная история болезни.">Für den Mutter-Kind-Pass sind 5 Untersuchungen, im Abstand von jeweils ca. einem Monat, vorgesehen. Dabei werden z.B. Hämoglobin/Hämatokritwerte festgestellt, Risikofaktoren für Kind und Mutter etabliert, und ausführliche Anamnese (=Gesundheitliche Vorgeschichte) durchgeführt.</p>
        <p><span data-lang-de="Mehr Informationen zu den einzelnen Untersuchungen finden Sie auf" data-lang-ru="Подробнее на">Mehr Informationen zu den einzelnen Untersuchungen finden Sie auf</span> <a href="https://www.oesterreich.gv.at/themen/familie_und_partnerschaft/geburt/5/Seite.082201.html" target="_blank" rel="noopener noreferrer">oesterreich.gv.at</a></p>

        <h3 style="margin-top: 28px; margin-bottom: 12px;" data-lang-de="Harn/Blutdruckkontrolle" data-lang-ru="Контроль кровяного давления">Harn/Blutdruckkontrolle</h3>
        <p data-lang-de="Sollte der Verdacht auf eine Harnweg- oder Stoffwechselerkrankung vorliegen — oder einfach zur Untersuchung auf Eiweiß, Nitrit etc. — können wir eine Harnprobe nehmen. Wir messen auch Ihren Blutdruck. So können wir Bluthochdruck schneller erkennen und dagegen vorgehen." data-lang-ru="Если есть подозрение на заболевание мочевыводящих путей или болезни обмена веществ или просто для проверки на белок, нитриты и т.д. — мы можем взять образец мочи. Мы также измеряем Ваше кровяное давление. Это позволяет нам быстрее выявить высокое кровяное давление и принять меры против него.">Sollte der Verdacht auf eine Harnweg- oder Stoffwechselerkrankung vorliegen — oder einfach zur Untersuchung auf Eiweiß, Nitrit etc. — können wir eine Harnprobe nehmen. Wir messen auch Ihren Blutdruck. So können wir Bluthochdruck schneller erkennen und dagegen vorgehen.</p>

        <h3 style="margin-top: 28px; margin-bottom: 12px;" data-lang-de="Ultraschall" data-lang-ru="Ультразвук">Ultraschall</h3>
        <p data-lang-de="Ultraschall ist ein wichtiges Diagnoseinstrument." data-lang-ru="Ультразвук является важным инструментом диагностики.">Ultraschall ist ein wichtiges Diagnoseinstrument.</p>

        <h3 style="margin-top: 28px; margin-bottom: 12px;" data-lang-de="Pränataldiagnostik" data-lang-ru="Пренатальная диагностика">Pränataldiagnostik</h3>
        <p data-lang-de="Pränataldiagnostische Verfahren im 1. und 2. Trimester der Schwangerschaft sind ein wichtiges Instrument zur Diagnose von Schwangerschaftserkrankungen." data-lang-ru="Пренатальные методы диагностики в 1. и 2. триместре беременности являются важным инструментом в диагностике заболеваний беременности.">Pränataldiagnostische Verfahren im 1. und 2. Trimester der Schwangerschaft sind ein wichtiges Instrument zur Diagnose von Schwangerschaftserkrankungen.</p>

        <div class="content-cta">
          <h3 data-lang-de="Möchten Sie einen Termin vereinbaren?" data-lang-ru="Хотите записаться на прием?">Möchten Sie einen Termin vereinbaren?</h3>
          <a href="/kontakt" class="btn btn-white" data-lang-de="Kontakt aufnehmen" data-lang-ru="Контакт">Kontakt aufnehmen</a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
