---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Kontakt — DDr. Anastasiya Krusche | Gynäkologin in Mödling & Hochstraß"
  description="Kontaktieren Sie DDr. Anastasiya Krusche. Ordination Hochstraß: +43 2773 43603. Ordination Mödling: +43 2236 392137. Online-Terminvereinbarung verfügbar."
>
  <Navbar slot="navbar" />

  <section class="kontakt-section" aria-labelledby="kontakt-heading">
    <div class="container">
      <h1 id="kontakt-heading" data-lang-de="Setzen Sie sich in Verbindung" data-lang-ru="Свяжитесь со мной">Setzen Sie sich in Verbindung</h1>

      <div style="margin-bottom: 40px; margin-top: 24px;">
        <a href="/termin" class="btn btn-primary" data-lang-de="Termin online buchen" data-lang-ru="Онлайн запись на приём">Termin online buchen</a>
      </div>

      <div class="kontakt-grid">
        <article class="kontakt-card">
          <h2>Ordination Hochstraß</h2>
          <p class="kontakt-badge" data-lang-de="Wahlärztin" data-lang-ru="ЧАСТНАЯ ОРДИНАЦИЯ">Wahlärztin</p>
          <address>
            <div class="kontakt-detail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Hochstraß 593, 3033 Hochstraß</span>
            </div>
            <div class="kontakt-detail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span><span data-lang-de="Montag" data-lang-ru="Понедельник">Montag</span>: 15:00 – 19:00 | <span data-lang-de="Mittwoch" data-lang-ru="Среда">Mittwoch</span>: 08:00 – 12:00</span>
            </div>
            <div class="kontakt-detail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.19 6.19l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:+4327734360">+43 2773 43603</a>
            </div>
          </address>
          <a href="https://booking.termindoc.at/e0a5913235694e6ea570f210d541621d" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="margin-top: 16px;" data-lang-de="Online Terminvereinbarung" data-lang-ru="Онлайн запись на приём">Online Terminvereinbarung</a>
        </article>

        <article class="kontakt-card">
          <h2>Ordination Mödling</h2>
          <p class="kontakt-badge" data-lang-de="Alle Krankenkassen (ÖGK, SVA, KFA Wien, BVA, BVAEB) und Privat" data-lang-ru="Кассовая ординация все страховки (ÖGK, SVA, KFA Wien, BVA, BVAEB) или частно">Alle Krankenkassen (ÖGK, SVA, KFA Wien, BVA, BVAEB) und Privat</p>
          <address>
            <div class="kontakt-detail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span>Enzersdorfer Straße 70/1, 2340 Mödling</span>
            </div>
            <div class="kontakt-detail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span><span data-lang-de="Mo, Di, Do" data-lang-ru="Пн, вт, чт">Mo, Di, Do</span>: 08:00 – 13:00 | <span data-lang-de="Mittwoch" data-lang-ru="Среда">Mittwoch</span>: 13:00 – 18:00</span>
            </div>
            <div class="kontakt-detail">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.19 6.19l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <a href="tel:+432236392137">+43 2236 392137</a>
            </div>
          </address>
          <a href="https://shop.timesloth.io/de/a/dr-krusche" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="margin-top: 16px;" data-lang-de="Online Terminvereinbarung" data-lang-ru="Онлайн запись на приём">Online Terminvereinbarung</a>
        </article>
      </div>

      <div class="kontakt-maps-grid">
        <div>
          <h3 style="margin-bottom: 16px; font-size: 20px;">Ordination Hochstraß</h3>
          <div class="kontakt-map">
            <iframe src="https://maps.google.com/maps?q=Hochstra%C3%9F+593,+3033+Hochstra%C3%9F,+%C3%96sterreich&z=15&output=embed" width="100%" height="400" style="border: 0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Karte Ordination Hochstraß"></iframe>
          </div>
        </div>
        <div>
          <h3 style="margin-bottom: 16px; font-size: 20px;">Ordination Mödling</h3>
          <div class="kontakt-map">
            <iframe src="https://maps.google.com/maps?q=Enzersdorfer+Stra%C3%9Fe+70,+2340+M%C3%B6dling,+%C3%96sterreich&z=15&output=embed" width="100%" height="400" style="border: 0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Karte Ordination Mödling"></iframe>
          </div>
        </div>
      </div>

      <!-- Kontaktformular -->
      <section class="content-section" style="padding-top: 48px;" aria-labelledby="contact-form-heading">
        <div class="content-narrow">
          <h2 id="contact-form-heading">Kontaktformular</h2>
          <p style="margin-bottom: 24px; color: #4A4A6A;">Schreiben Sie uns eine Nachricht. Wir melden uns so bald wie möglich bei Ihnen.</p>

          {Astro.url.searchParams.get('success') === '1' && (
            <div class="form-success" role="alert">
              <strong>Vielen Dank!</strong> Ihre Nachricht wurde erfolgreich gesendet.
            </div>
          )}
          {Astro.url.searchParams.get('error') === 'validation' && (
            <div class="form-server-error" role="alert">
              Bitte füllen Sie alle Pflichtfelder korrekt aus.
            </div>
          )}

          <form method="POST" action="/api/contact" id="contact-form">
            <div class="form-group">
              <label for="contact-name">Name *</label>
              <input type="text" id="contact-name" name="name" required minlength="2" autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="contact-email">E-Mail *</label>
              <input type="email" id="contact-email" name="email" required autocomplete="email" />
            </div>
            <div class="form-group">
              <label for="contact-phone">Telefon</label>
              <input type="tel" id="contact-phone" name="phone" autocomplete="tel" />
            </div>
            <div class="form-group">
              <label for="contact-message">Nachricht *</label>
              <textarea id="contact-message" name="message" required minlength="10" rows="5"></textarea>
            </div>
            <button type="submit" class="btn btn-primary" style="width: auto;">Nachricht senden</button>
          </form>
        </div>
      </section>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
